# ==========================
# TRD Store – Environment Variables (Next.js frontend)
# Copy to .env.local and fill values
# ==========================

# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Site name shown in <title> & header
NEXT_PUBLIC_SITE_NAME=TRD Store

# --- Payment (SSLCommerz redirect URLs) ---
# Must be publicly accessible when using SSLCommerz live mode
NEXT_PUBLIC_SSLCZ_SUCCESS_URL=http://localhost:3000/checkout/result
NEXT_PUBLIC_SSLCZ_FAIL_URL=http://localhost:3000/checkout/result
NEXT_PUBLIC_SSLCZ_CANCEL_URL=http://localhost:3000/checkout/result

# --- Feature flags (set to "true" to enable) ---

# Rating / review system
# TRD_NOTE: kept false to match clean-disable commit 6ff99c8
NEXT_PUBLIC_ENABLE_RATINGS=false

# "Free Delivery" toggle in seller product form
# TRD_NOTE: hidden for now
NEXT_PUBLIC_SELLER_SHOW_FREE_DELIVERY=false

# "My Orders" section inside seller dashboard
# TRD_NOTE: hidden for now
NEXT_PUBLIC_SELLER_SHOW_ORDERS=false
