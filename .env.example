# Environment Variables Template for Production
# Copy this file to both backend and frontend directories and fill in actual values
# DO NOT commit this file to version control!

# ===== Django Backend Settings (.env in /backend) =====

# Security
DEBUG=False
SECRET_KEY=generate-a-secure-random-key-here-at-least-50-characters
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,api.your-domain.com,your-server-ip

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=trd_store
DB_USER=trd_store
DB_PASSWORD=secure_database_password_here_min_16_chars
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# Redis Cache
CACHE_ENABLED=True
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# Email Configuration (Gmail example)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password-not-regular-password
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# SSLCommerz Payment Gateway
PAYMENT_GATEWAY=sslcommerz
SSLCZ_STORE_ID=your-store-id
SSLCZ_STORE_PASSWD=your-store-password
SSLCZ_IS_SANDBOX=False
BACKEND_URL=https://api.your-domain.com
FRONTEND_URL=https://your-domain.com
SSLCZ_IPN_URL=https://api.your-domain.com/api/v1/payments/ipn/
SSLCZ_SUCCESS_URL=https://api.your-domain.com/api/v1/payments/success/
SSLCZ_FAIL_URL=https://api.your-domain.com/api/v1/payments/fail/
SSLCZ_CANCEL_URL=https://api.your-domain.com/api/v1/payments/cancel/

# Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY=True

# CORS Settings
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com,http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=  # Optional: Sentry error tracking URL

# AWS S3 (Optional - for file storage)
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Timezone
TIME_ZONE=UTC

# ===== Next.js Frontend Settings (.env.production.local in /frontend) =====

# API Configuration
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Application Settings
NEXT_PUBLIC_APP_NAME=TRD Store
NEXT_PUBLIC_APP_DESCRIPTION=Smart Multi-Vendor E-Commerce Platform
NEXT_PUBLIC_CURRENCY=BDT
NEXT_PUBLIC_CURRENCY_SYMBOL=৳

# External Services
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=  # Optional: Google Analytics ID
NEXT_PUBLIC_SENTRY_DSN=  # Optional: Sentry DSN for error tracking

# Feature Flags
NEXT_PUBLIC_ENABLE_RECOMMENDATIONS=true
NEXT_PUBLIC_ENABLE_SELLER_DASHBOARD=true
NEXT_PUBLIC_ENABLE_CHECKOUT=true

# Performance
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true
NEXT_PUBLIC_COMPRESSION=true

# ===== Notes =====

# 1. SECRET_KEY: Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'

# 2. SSLCommerz: Get credentials from https://developer.sslcommerz.com/registration/

# 3. EMAIL_HOST_PASSWORD: For Gmail, use App Passwords (not your regular password)
#    Enable 2FA and generate an app password at https://myaccount.google.com/apppasswords

# 4. All sensitive values should be generated and kept secure
#    Use a password manager or secrets management tool

# 5. Never commit .env files to version control
#    Add to .gitignore: *.env, .env.*, !.env.example

# 6. In production, use environment management services:
#    - AWS Systems Manager Parameter Store
#    - HashiCorp Vault
#    - Azure Key Vault
#    - Google Secret Manager
